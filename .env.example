# Database
DATABASE_URL=postgres://user:password@localhost:5432/bominal

# Server
APP_ENV=development
BIND_ADDR=0.0.0.0:4001
# PORT=8080  # Cloud Run sets this automatically

# Auth
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:4000

# OAuth (optional — demo auth works without these)
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# Logging
RUST_LOG=bominal_server=debug,tower_http=debug
